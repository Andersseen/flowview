---
import Layout from "../layouts/Layout.astro";
import authoringExample from "../snippets/events-author.astro.txt?raw";
import compiledExample from "../snippets/events-compiled.html.txt?raw";

function save(event: Event) {
  const output = document.querySelector("#event-output");
  const button = event.currentTarget;
  if (button instanceof HTMLElement) {
    button.textContent = "Saved";
  }
  if (output) {
    output.textContent = `Saved from a ${event.type} event`;
  }
}

function removeItem(id: string, element: HTMLElement) {
  const output = document.querySelector("#event-output");
  if (element instanceof HTMLElement) {
    element.setAttribute("disabled", "true");
    element.textContent = "Removed";
  }
  if (output) {
    output.textContent = `Removed ${id} with a serialized argument`;
  }
}

function previewInput(event: Event) {
  const output = document.querySelector("#event-output");
  const target = event.target;
  if (output && target && "value" in target) {
    output.textContent = `Input event value: ${String(target.value)}`;
  }
}
---

<Layout
  title="Flowmark Events compiler"
  description="Angular-style event binding syntax compiled for Astro pages."
>
  <main class="grid gap-8 py-12 md:py-14">
    <header class="page-frame grid gap-5">
      <p
        class="w-fit rounded-md border border-border bg-background px-3 py-1 text-sm font-bold uppercase tracking-normal text-muted-foreground"
      >
        Flowmark Events
      </p>
      <h1
        class="max-w-4xl text-4xl font-black tracking-normal text-foreground md:text-6xl"
      >
        Use (click) in Astro. Skip the listener boilerplate.
      </h1>
      <p class="max-w-3xl text-lg text-muted-foreground md:text-xl">
        The events compiler brings Angular's event-binding DX to plain Astro
        markup. Write handlers in frontmatter, use
        <code
          class="rounded-md border border-border bg-muted/45 px-1 py-0.5 text-[0.9em] text-foreground"
          >(event)="handler()"</code
        > in the template, and Flowmark emits the tiny client module that binds native
        browser listeners.
      </p>
    </header>

    <section class="page-frame grid gap-6 md:grid-cols-[0.8fr_1.2fr]">
      <div class="preview-surface grid min-h-0 content-start gap-5">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <span
            class="inline-flex w-fit items-center rounded-full border border-border bg-[hsl(var(--warning)_/_0.16)] px-3 py-1 text-xs font-bold text-[hsl(32_95%_34%)]"
          >
            Live Astro page
          </span>
          <span class="text-sm font-bold text-muted-foreground">
            Compiled from (click) and (input)
          </span>
        </div>

        <div class="flex flex-wrap gap-3">
          <button
            (click)="save($event)"
            class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-bold text-primary-foreground"
          >
            Save
          </button>

          <button
            (click)="removeItem('item-1', $el)"
            class="inline-flex items-center rounded-md border border-border bg-background px-4 py-2 text-sm font-bold text-foreground disabled:opacity-60"
          >
            Remove item 1
          </button>
        </div>

        <label
          class="grid gap-2 text-sm font-extrabold text-foreground"
          for="event-demo-input"
        >
          <span>Try an input event</span>
          <input
            id="event-demo-input"
            (input)="previewInput($event)"
            placeholder="Type to trigger (input)"
            class="w-full rounded-md border border-border bg-background px-4 py-3 font-semibold text-foreground placeholder:text-muted-foreground"
          />
        </label>

        <p
          id="event-output"
          class="min-h-14 rounded-md border border-border bg-background p-4 text-sm font-bold text-muted-foreground"
        >
          Click an action to see the compiled event handlers run.
        </p>

        <div class="flex flex-wrap gap-2">
          <span
            class="rounded-full border border-border bg-muted/45 px-3 py-1.5 text-xs font-extrabold text-muted-foreground"
            >$event</span
          >
          <span
            class="rounded-full border border-border bg-muted/45 px-3 py-1.5 text-xs font-extrabold text-muted-foreground"
            >$el</span
          >
          <span
            class="rounded-full border border-border bg-muted/45 px-3 py-1.5 text-xs font-extrabold text-muted-foreground"
            >literal args</span
          >
          <span
            class="rounded-full border border-border bg-muted/45 px-3 py-1.5 text-xs font-extrabold text-muted-foreground"
            >native events</span
          >
        </div>
      </div>

      <div class="preview-surface grid min-h-0 gap-4">
        <div
          class="grid gap-3 rounded-md border border-border bg-background p-5"
        >
          <div class="flex items-center justify-between gap-3">
            <span class="text-sm font-extrabold text-foreground">
              Author in Astro
            </span>
            <code class="text-xs text-muted-foreground">.astro</code>
          </div>
          <vertex-editor-lite
            value={authoringExample}
            language="html"
            theme="dark"
            height="420px"
            font-size="14"
            class="h-[260px] overflow-hidden rounded-md border border-border md:h-[420px]"
          ></vertex-editor-lite>
        </div>

        <div
          class="grid gap-3 rounded-md border border-border bg-background p-5"
        >
          <div class="flex items-center justify-between gap-3">
            <span class="text-sm font-extrabold text-foreground">
              Compiler output
            </span>
            <code class="text-xs text-muted-foreground">HTML + JS</code>
          </div>
          <vertex-editor-lite
            value={compiledExample}
            language="html"
            theme="dark"
            height="270px"
            font-size="14"
            class="h-[200px] overflow-hidden rounded-md border border-border md:h-[270px]"
          ></vertex-editor-lite>
        </div>
      </div>
    </section>

    <section
      class="page-frame grid gap-4 md:grid-cols-3"
      aria-label="Events compiler pipeline"
    >
      <article
        class="grid min-h-44 content-start gap-3 rounded-md border border-border bg-background p-5"
      >
        <span
          class="inline-flex w-fit items-center rounded-full border border-border bg-[hsl(var(--warning)_/_0.16)] px-3 py-1 text-xs font-bold text-[hsl(32_95%_34%)]"
        >
          01
        </span>
        <h2 class="text-base font-extrabold tracking-normal">
          Write event intent in markup
        </h2>
        <p class="text-muted-foreground">
          Use `(click)`, `(input)`, or any native event name where the user
          action happens.
        </p>
      </article>
      <article
        class="grid min-h-44 content-start gap-3 rounded-md border border-border bg-background p-5"
      >
        <span
          class="inline-flex w-fit items-center rounded-full border border-border bg-[hsl(var(--success)_/_0.13)] px-3 py-1 text-xs font-bold text-[hsl(var(--success))]"
        >
          02
        </span>
        <h2 class="text-base font-extrabold tracking-normal">
          Move safe handlers to the client
        </h2>
        <p class="text-muted-foreground">
          Flowmark reads Astro frontmatter, extracts the referenced functions,
          and rejects handlers that capture server-only values.
        </p>
      </article>
      <article
        class="grid min-h-44 content-start gap-3 rounded-md border border-border bg-background p-5"
      >
        <span
          class="inline-flex w-fit items-center rounded-full border border-border bg-secondary px-3 py-1 text-xs font-bold text-secondary-foreground"
        >
          03
        </span>
        <h2 class="text-base font-extrabold tracking-normal">
          Bind native listeners at runtime
        </h2>
        <p class="text-muted-foreground">
          The browser receives data attributes plus a small runtime that calls
          `addEventListener` for you.
        </p>
      </article>
    </section>
  </main>
</Layout>
