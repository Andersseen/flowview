---
const context = {
  name: "Flowmark",
  markup: `<img src=x onerror="globalThis.__flowmarkXss = true">`,
};
---

<template flowmark={context} is:raw>
  <main>
    <p id="space"><span>Hello </span>{{ context.name }}</p>
    <pre id="pre">first
  second</pre>
    <p id="escaped">{{ context.markup }}</p>
    <!-- @if inside an HTML comment is literal template content. -->
    <p id="literal-at" title="@if inside an attribute is literal">contact@if.example</p>
  </main>
</template>
