---
import Layout from "../layouts/Layout.astro";
import ExampleSection from "../components/ExampleSection.astro";
import Features from "../components/Features.astro";
import Footer from "../components/Footer.astro";
import GettingStarted from "../components/GettingStarted.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import SyntaxShowcase from "../components/SyntaxShowcase.astro";

import {
  exampleSectionContext,
  featuresContext,
  footerContext,
  gettingStartedContext,
  heroContext,
  site,
  syntaxContext,
} from "../data";
---

<Layout title={site.title} description={site.description} siteUrl={site.url}>
  <Hero context={heroContext} />
  <Features context={featuresContext} />
  <SyntaxShowcase context={syntaxContext} />
  <HowItWorks />
  <ExampleSection context={exampleSectionContext} />
  <GettingStarted context={gettingStartedContext} />
  <Footer context={footerContext} />
</Layout>
