---
import "../styles/global.css";
import { navItems } from "../data/navigation";

export interface Props {
  title: string;
  description?: string;
  siteUrl?: string;
}

const {
  title,
  description = "Flowmark compiles HTML-like templates with Angular-inspired control flow into plain JavaScript render functions.",
  siteUrl = "https://flowmark.example",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const serializedNavItems = JSON.stringify(navItems);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="description" content={description} />
    <meta
      name="theme-color"
      content="hsl(210 20% 98%)"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="hsl(222 47% 5%)"
      media="(prefers-color-scheme: dark)"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("flowmark-theme");
        const systemDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const mode =
          stored === "dark" || stored === "light"
            ? stored
            : systemDark
              ? "dark"
              : "light";
        document.documentElement.setAttribute("data-mode", mode);
      })();
    </script>
    <script>
      import "../scripts/web-components";
    </script>
    <script is:inline src="/web-editor-lite.min.js"></script>
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-primary-foreground"
    >
      Skip to content
    </a>

    <div class="app-shell">
      <and-navbar
        class="block border-b border-border bg-background/95"
        items={serializedNavItems}
        variant="default"
        position="sticky"
        active-mode="route"
        item-variant="filled"
        mobile-breakpoint="768"
        minimal-breakpoint="768"
        aria-nav-label="Flowmark navigation"
      >
        <a
          slot="start"
          href="/"
          class="flex items-center gap-2 px-3 py-2 text-sm font-bold text-foreground"
        >
          <span
            class="grid size-7 place-items-center rounded-md bg-primary text-xs font-black text-primary-foreground"
          >
            F
          </span>
          <span class="hidden sm:inline">Flowmark</span>
        </a>

        <div slot="end" class="flex items-center gap-1">
          <a
            href="https://github.com/andersseen/flowmark"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex size-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
            aria-label="View Flowmark on GitHub"
          >
            <and-icon name="github" size="20" aria-hidden="true"></and-icon>
          </a>

          <and-button
            type="button"
            class="theme-toggle"
            size="icon"
            variant="ghost"
            aria-label="Toggle theme"
          >
            <and-icon
              name="sun"
              class="theme-icon-light"
              size="18"
              aria-hidden="true"
              style="display: block;"
            ></and-icon>
            <and-icon
              name="moon"
              class="theme-icon-dark"
              size="18"
              aria-hidden="true"
              style="display: none;"
            ></and-icon>
          </and-button>
        </div>

        <div
          slot="mobile-nav"
          class="flex flex-col gap-3 p-4"
        >
          <a
            href="https://github.com/andersseen/flowmark"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-foreground transition-colors hover:bg-accent"
          >
            <and-icon name="github" size="18" aria-hidden="true"></and-icon>
            GitHub
          </a>

          <and-button
            type="button"
            class="theme-toggle w-full justify-start"
            size="sm"
            variant="ghost"
            aria-label="Toggle theme"
          >
            <and-icon
              name="sun"
              class="theme-icon-light"
              size="18"
              aria-hidden="true"
              style="display: block;"
            ></and-icon>
            <and-icon
              name="moon"
              class="theme-icon-dark"
              size="18"
              aria-hidden="true"
              style="display: none;"
            ></and-icon>
            <span class="theme-label-light">Light theme</span>
            <span
              class="theme-label-dark"
              style="display: none;"
            >Dark theme</span>
          </and-button>
        </div>
      </and-navbar>

      <main id="main-content">
        <slot />
      </main>
    </div>

    <script is:inline>
      (function () {
        function applyMode(mode) {
          const isDark = mode === "dark";
          document.documentElement.setAttribute("data-mode", mode);

          document.querySelectorAll(".theme-toggle").forEach((button) => {
            button.setAttribute("variant", "ghost");
            button.setAttribute(
              "aria-label",
              isDark ? "Switch to light theme" : "Switch to dark theme",
            );
          });

          document
            .querySelectorAll(".theme-icon-light")
            .forEach((icon) => (icon.style.display = isDark ? "none" : "block"));
          document
            .querySelectorAll(".theme-icon-dark")
            .forEach((icon) => (icon.style.display = isDark ? "block" : "none"));
          document
            .querySelectorAll(".theme-label-light")
            .forEach((label) => (label.style.display = isDark ? "none" : "block"));
          document
            .querySelectorAll(".theme-label-dark")
            .forEach((label) => (label.style.display = isDark ? "block" : "none"));
        }

        const currentMode =
          document.documentElement.getAttribute("data-mode") || "light";
        applyMode(currentMode);

        document.querySelectorAll(".theme-toggle").forEach((button) => {
          button.addEventListener("click", function () {
            const current =
              document.documentElement.getAttribute("data-mode") || "light";
            const next = current === "dark" ? "light" : "dark";
            localStorage.setItem("flowmark-theme", next);
            applyMode(next);
          });
        });
      })();
    </script>
  </body>
</html>
