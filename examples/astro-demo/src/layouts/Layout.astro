---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Flowmark compiles HTML-like templates with Angular-inspired control flow into plain JavaScript render functions.",
} = Astro.props;

const navItems = JSON.stringify([
  { id: "demo", label: "Demo", href: "/" },
  { id: "attention", label: "Attention", href: "/attention" },
  { id: "empty", label: "Empty state", href: "/empty" },
  {
    id: "github",
    label: "GitHub",
    href: "https://github.com/andersseen/flowmark",
    target: "_blank",
  },
]);
---

<!doctype html>
<html lang="en" data-mode="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script>
      import "../scripts/web-components";
    </script>
  </head>
  <body>
    <div class="app-shell">
      <and-navbar
        class="block border-b border-border bg-background/95"
        items={navItems}
        variant="default"
        position="sticky"
        active-mode="route"
        item-variant="filled"
        aria-nav-label="Flowmark demo navigation"
      >
        <a
          slot="start"
          href="/"
          class="flex items-center gap-2 px-3 py-2 text-sm font-bold text-foreground"
        >
          <span
            class="grid size-7 place-items-center rounded-md bg-primary text-xs font-black text-primary-foreground"
          >
            F
          </span>
          Flowmark
        </a>
      </and-navbar>

      <slot />

      <footer class="border-t border-border bg-card">
        <div
          class="page-frame flex flex-col gap-3 py-8 text-sm text-muted-foreground sm:flex-row sm:items-center sm:justify-between"
        >
          <p>
            Built with Astro, Flowmark, Tailwind 4, and Andersseen Web
            Components.
          </p>
          <a class="font-medium text-foreground hover:underline" href="/"
            >Back to demo</a
          >
        </div>
      </footer>
    </div>
  </body>
</html>
