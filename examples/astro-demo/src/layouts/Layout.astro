---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  siteUrl?: string;
}

const {
  title,
  description = "Flowmark compiles HTML-like templates with Angular-inspired control flow into plain JavaScript render functions.",
  siteUrl = "https://flowmark.example",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, siteUrl).toString();

const navItems = JSON.stringify([
  { id: "home", label: "Home", href: "/" },
  {
    id: "github",
    label: "GitHub",
    href: "https://github.com/andersseen/flowmark",
    target: "_blank",
  },
]);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="theme-color"
      content="hsl(210 20% 98%)"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="hsl(222 47% 5%)"
      media="(prefers-color-scheme: dark)"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script>
      import "../scripts/web-components";
    </script>
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-primary-foreground"
    >
      Skip to content
    </a>

    <div class="app-shell">
      <and-navbar
        class="block border-b border-border bg-background/95"
        items={navItems}
        variant="default"
        position="sticky"
        active-mode="route"
        item-variant="filled"
        aria-nav-label="Flowmark navigation"
      >
        <a
          slot="start"
          href="/"
          class="flex items-center gap-2 px-3 py-2 text-sm font-bold text-foreground"
        >
          <span
            class="grid size-7 place-items-center rounded-md bg-primary text-xs font-black text-primary-foreground"
          >
            F
          </span>
          Flowmark
        </a>
      </and-navbar>

      <main id="main-content">
        <slot />
      </main>
    </div>
  </body>
</html>
