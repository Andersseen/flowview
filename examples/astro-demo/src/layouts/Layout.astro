---
import "../styles/global.css";
import { navItems } from "../data/navigation";

export interface Props {
  title: string;
  description?: string;
  siteUrl?: string;
}

const {
  title,
  description = "Flowmark compiles HTML-like templates with Angular-inspired control flow into plain JavaScript render functions.",
  siteUrl = "https://flowmark.example",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const serializedNavItems = JSON.stringify(navItems);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="theme-color"
      content="hsl(210 20% 98%)"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="hsl(222 47% 5%)"
      media="(prefers-color-scheme: dark)"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("flowmark-theme");
        const systemDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const mode =
          stored === "dark" || stored === "light"
            ? stored
            : systemDark
              ? "dark"
              : "light";
        document.documentElement.setAttribute("data-mode", mode);
      })();
    </script>
    <script>
      import "../scripts/web-components";
    </script>
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-primary-foreground"
    >
      Skip to content
    </a>

    <div class="app-shell">
      <and-navbar
        class="block border-b border-border bg-background/95"
        items={serializedNavItems}
        variant="default"
        position="sticky"
        active-mode="route"
        item-variant="filled"
        aria-nav-label="Flowmark navigation"
      >
        <a
          slot="start"
          href="/"
          class="flex items-center gap-2 px-3 py-2 text-sm font-bold text-foreground"
        >
          <span
            class="grid size-7 place-items-center rounded-md bg-primary text-xs font-black text-primary-foreground"
          >
            F
          </span>
          Flowmark
        </a>

        <div slot="end" class="flex items-center gap-1">
          <a
            href="https://github.com/andersseen/flowmark"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex size-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
            aria-label="View Flowmark on GitHub"
          >
            <and-icon name="github" size="20" aria-hidden="true"></and-icon>
          </a>

          <div
            class="inline-flex items-center rounded-md border border-border bg-background p-0.5"
            role="group"
            aria-label="Theme switcher"
          >
            <and-button
              type="button"
              id="theme-light"
              size="icon"
              variant="default"
              aria-label="Switch to light theme"
            >
              <and-icon name="sun" size="16" aria-hidden="true"></and-icon>
            </and-button>
            <and-button
              type="button"
              id="theme-dark"
              size="icon"
              variant="outline"
              aria-label="Switch to dark theme"
            >
              <and-icon name="moon" size="16" aria-hidden="true"></and-icon>
            </and-button>
          </div>
        </div>
      </and-navbar>

      <main id="main-content">
        <slot />
      </main>
    </div>

    <script is:inline>
      (function () {
        const lightButton = document.getElementById("theme-light");
        const darkButton = document.getElementById("theme-dark");
        if (!lightButton || !darkButton) return;

        function applyMode(mode) {
          document.documentElement.setAttribute("data-mode", mode);
          const isDark = mode === "dark";
          lightButton.setAttribute("variant", isDark ? "outline" : "default");
          darkButton.setAttribute("variant", isDark ? "default" : "outline");
          lightButton.setAttribute(
            "aria-label",
            isDark ? "Switch to light theme" : "Light theme active",
          );
          darkButton.setAttribute(
            "aria-label",
            isDark ? "Dark theme active" : "Switch to dark theme",
          );
        }

        lightButton.addEventListener("click", function () {
          localStorage.setItem("flowmark-theme", "light");
          applyMode("light");
        });

        darkButton.addEventListener("click", function () {
          localStorage.setItem("flowmark-theme", "dark");
          applyMode("dark");
        });

        const currentMode =
          document.documentElement.getAttribute("data-mode") || "light";
        applyMode(currentMode);
      })();
    </script>
  </body>
</html>
