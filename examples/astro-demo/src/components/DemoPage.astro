---
import { demoContext } from "../data/context";

export interface Props {
  mode?: "main" | "empty";
}

const { mode = "main" } = Astro.props;

const context = {
  ...demoContext,
  mode,
  badge:
    mode === "empty"
      ? "Inline Flowmark empty state"
      : "Inline Flowmark in Astro",
  title: mode === "empty" ? "Empty State" : demoContext.title,
  description:
    mode === "empty"
      ? "The same inline Flowmark template renders the fallback branch when ctx.products is empty."
      : demoContext.description,
  featured: mode !== "empty",
  products: mode === "empty" ? [] : demoContext.products,
};
---

<!-- prettier-ignore -->
<template flowmark is:raw context={context}>
  <header class="hero-panel">
    <div class="page-frame grid gap-8 py-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
      <div class="max-w-3xl">
        <and-badge variant="outline">{{ ctx.badge }}</and-badge>
        <h1 class="mt-5 text-4xl font-black tracking-normal text-foreground sm:text-5xl">
          {{ ctx.title }}
        </h1>
        <p class="mt-4 max-w-2xl text-lg text-muted-foreground">
          {{ ctx.description }}
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          @if (ctx.mode === 'empty') {
            <and-button href="/" variant="default">Back to main demo</and-button>
          } @else {
            <and-button href="/empty" variant="default">View empty state</and-button>
          }
          <and-button href="https://github.com/andersseen/flowmark" target="_blank" variant="outline">
            GitHub
          </and-button>
        </div>
      </div>

      <and-card variant="elevated" padded class="block">
        <div class="grid gap-4">
          <div>
            <p class="text-sm font-semibold text-muted-foreground">Astro-native authoring</p>
            <p class="mt-1 text-2xl font-bold text-foreground">\@if, \@for, \@switch</p>
          </div>
          <div class="grid grid-cols-3 gap-2 text-sm">
            <div class="rounded-md border border-border p-3">
              <p class="font-bold">Inline</p>
              <p class="text-muted-foreground">template</p>
            </div>
            <div class="rounded-md border border-border p-3">
              <p class="font-bold">Rust</p>
              <p class="text-muted-foreground">compiler</p>
            </div>
            <div class="rounded-md border border-border p-3">
              <p class="font-bold">Astro</p>
              <p class="text-muted-foreground">host</p>
            </div>
          </div>
        </div>
      </and-card>
    </div>
  </header>

  <main class="page-frame py-10">
    <section class="grid gap-6 lg:grid-cols-4 md:grid-cols-2">
      <and-card variant="outline" padded class="block">
        <p class="text-sm font-semibold text-muted-foreground">Total products</p>
        <p class="mt-1 text-3xl font-bold text-foreground">{{ ctx.products.length }}</p>
      </and-card>
      <and-card variant="outline" padded class="block">
        <p class="text-sm font-semibold text-muted-foreground">In stock</p>
        <p class="mt-1 text-3xl font-bold text-foreground">{{ ctx.products.filter(p => p.status === 'available').length }}</p>
      </and-card>
      <and-card variant="outline" padded class="block">
        <p class="text-sm font-semibold text-muted-foreground">On sale</p>
        <p class="mt-1 text-3xl font-bold text-foreground">{{ ctx.products.filter(p => p.status === 'sale').length }}</p>
      </and-card>
      <and-card variant="outline" padded class="block">
        <p class="text-sm font-semibold text-muted-foreground">Out of stock</p>
        <p class="mt-1 text-3xl font-bold text-foreground">{{ ctx.products.filter(p => p.status === 'unavailable').length }}</p>
      </and-card>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[0.85fr_1.15fr]">
      <and-card variant="outline" padded class="block">
        <div class="grid gap-5">
          <div>
            <and-badge variant="secondary">How it works</and-badge>
            <h2 class="mt-4 text-2xl font-bold text-foreground">Flowmark inside Astro</h2>
            <p class="mt-3 text-muted-foreground">
              This page uses a real Flowmark template inside a .astro component.
              The Astro integration compiles it before Astro parses the page.
            </p>
          </div>
          <div class="grid gap-3 text-sm">
            @for (note of ctx.notes; track note.title) {
              <div class="rounded-md border border-border p-4">
                <p class="font-semibold">{{ note.title }}</p>
                <p class="mt-1 text-muted-foreground">{{ note.body }}</p>
              </div>
            }
          </div>
        </div>
      </and-card>

      <and-card variant="outline" class="block h-full">
        <and-card-header>
          <div class="flex items-center justify-between gap-3">
            <and-card-title>Product inventory</and-card-title>
            <and-badge variant="secondary">Flowmark</and-badge>
          </div>
          <and-card-description>
            The table below is rendered by \@for, \@empty, and \@switch.
          </and-card-description>
        </and-card-header>
        <and-card-content>
          <div class="preview-surface flow-preview">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-border">
                  <th class="py-2 pr-4 font-semibold">Product</th>
                  <th class="py-2 pr-4 font-semibold">Category</th>
                  <th class="py-2 pr-4 font-semibold">Price</th>
                  <th class="py-2 pr-4 font-semibold">Stock</th>
                  <th class="py-2 font-semibold">Status</th>
                </tr>
              </thead>
              <tbody>
                @for (product of ctx.products; track product.id) {
                  <tr class="border-b border-border last:border-b-0">
                    <td class="py-3 pr-4">
                      <p class="font-semibold">{{ product.name }}</p>
                      <p class="text-muted-foreground">{{ product.description }}</p>
                    </td>
                    <td class="py-3 pr-4 text-muted-foreground">{{ product.category }}</td>
                    <td class="py-3 pr-4 font-medium">{{ ctx.store.currency }}{{ product.price }}</td>
                    <td class="py-3 pr-4">{{ product.stock }}</td>
                    <td class="py-3">
                      @switch (product.status) {
                        @case ('available') {
                          <span class="tag available">In stock</span>
                        }
                        @case ('sale') {
                          <span class="tag sale">On sale</span>
                        }
                        @default {
                          <span class="tag unavailable">Out of stock</span>
                        }
                      }
                    </td>
                  </tr>
                } @empty {
                  <tr>
                    <td colspan="5" class="py-6 text-center text-muted-foreground">
                      <p class="empty">No products found.</p>
                    </td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        </and-card-content>
      </and-card>
    </section>
  </main>
</template>
