---
import { heroContext } from "../data/hero";
import type { HeroContext } from "../data/types";

export interface Props {
  context?: HeroContext;
}

const { context = heroContext } = Astro.props;
---

<template flowview={context} is:raw>
  <header class="hero-panel">
    <div class="page-frame grid gap-8 py-16 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-black tracking-normal text-foreground sm:text-6xl">
          {{ context.title }}
        </h1>
        <p class="mt-4 max-w-2xl text-lg text-muted-foreground sm:text-xl">
          {{ context.tagline }}
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          @if (context.ctaPrimary) {
            <and-button href="{{ context.ctaPrimary.href }}" variant="default">
              {{ context.ctaPrimary.text }}
            </and-button>
          }
          @if (context.ctaSecondary) {
            <and-button href="{{ context.ctaSecondary.href }}" variant="outline" target="_blank">
              {{ context.ctaSecondary.text }}
            </and-button>
          }
        </div>
      </div>

      <and-card variant="elevated" padded class="block">
        <div class="grid gap-4">
          <div>
            <p class="text-sm font-semibold text-muted-foreground">Astro-native authoring</p>
            <p class="mt-1 text-2xl font-bold text-foreground">\@if, \@else if, \@for, \@switch</p>
          </div>
          <div class="grid grid-cols-3 gap-2 text-sm">
            <div class="rounded-md border border-border p-3">
              <p class="font-bold">Inline</p>
              <p class="text-muted-foreground">template</p>
            </div>
            <div class="rounded-md border border-border p-3">
              <p class="font-bold">Rust</p>
              <p class="text-muted-foreground">compiler</p>
            </div>
            <div class="rounded-md border border-border p-3">
              <p class="font-bold">Astro</p>
              <p class="text-muted-foreground">host</p>
            </div>
          </div>
        </div>
      </and-card>
    </div>
  </header>
</template>
