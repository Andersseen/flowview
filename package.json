{
  "name": "flowmark",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "pnpm run build:rust && pnpm run build:runtime",
    "build:rust": "cargo build --workspace",
    "build:runtime": "pnpm --filter @flowmark/runtime build",
    "test": "pnpm run test:rust && pnpm run test:runtime",
    "test:rust": "cargo test --workspace",
    "test:runtime": "pnpm --filter @flowmark/runtime test",
    "format": "pnpm run format:rust && pnpm run format:ts",
    "format:rust": "cargo fmt --all",
    "format:ts": "prettier --write --no-error-on-unmatched-pattern \"packages/**/*.ts\" \"packages/**/*.mjs\" \"examples/**/*.ts\" \"examples/**/*.mjs\" ",
    "compile:example": "cargo run -p flowmark-cli -- compile examples/basic/for.flow",
    "demo": "pnpm --filter @flowmark/astro-demo dev",
    "build:demo": "pnpm --filter @flowmark/astro-demo run build",
    "deploy:demo": "pnpm run build:demo && pnpm exec wrangler pages deploy examples/astro-demo/dist --project-name=flowmark-demo"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "wrangler": "^3.0.0"
  }
}
