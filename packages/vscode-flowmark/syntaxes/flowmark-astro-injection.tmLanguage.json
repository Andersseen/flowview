{
  "name": "Flowmark Astro Injection",
  "scopeName": "flowmark.astro.injection",
  "injectionSelector": "L:source.astro -comment -string",
  "patterns": [
    {
      "name": "meta.embedded.block.flowmark.astro",
      "begin": "(<)(template)(?=[\\s>])(?=[^>]*\\bflowmark\\b)((?:\\\"(?:\\\\.|[^\\\"])*\\\"|'(?:\\\\.|[^'])*'|\\{(?:[^{}]|\\{[^{}]*\\})*\\}|[^>])*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.template.astro.flowmark" },
        "3": { "name": "meta.tag.attributes.astro" },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(template)(\\s*>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.template.astro.flowmark" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "contentName": "meta.embedded.flowmark",
      "patterns": [{ "include": "source.flowmark" }]
    },
    {
      "name": "meta.embedded.block.flowmark.astro",
      "begin": "(<)(Flowmark)\\b((?:[^>]|\\n)*?\\bis:raw\\b(?:[^>]|\\n)*?)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "support.class.component.astro.flowmark" },
        "3": { "name": "meta.tag.attributes.astro" },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(Flowmark)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "support.class.component.astro.flowmark" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "contentName": "meta.embedded.flowmark",
      "patterns": [{ "include": "source.flowmark" }]
    }
  ]
}
