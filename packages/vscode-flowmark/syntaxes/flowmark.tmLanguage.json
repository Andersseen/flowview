{
  "name": "Flowmark",
  "scopeName": "source.flowmark",
  "patterns": [
    { "include": "#comments" },
    { "include": "#escape" },
    { "include": "#interpolation" },
    { "include": "#control-keyword" },
    { "include": "#control-expression" },
    { "include": "#block" },
    { "include": "text.html.basic" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.html.flowmark",
          "begin": "<!--",
          "end": "-->"
        }
      ]
    },
    "escape": {
      "patterns": [
        {
          "name": "constant.character.escape.flowmark",
          "match": "\\\\[@{}\\\\]"
        }
      ]
    },
    "interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.flowmark",
          "begin": "\\{\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.section.embedded.begin.flowmark" }
          },
          "end": "\\}\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.embedded.end.flowmark" }
          },
          "patterns": [{ "include": "source.js" }]
        }
      ]
    },
    "control-keyword": {
      "patterns": [
        {
          "match": "(@)(else if)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.keyword.flowmark" },
            "2": { "name": "keyword.control.flowmark" }
          }
        },
        {
          "match": "(@)(if)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.keyword.flowmark" },
            "2": { "name": "keyword.control.flowmark" }
          }
        },
        {
          "match": "(@)(else)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.keyword.flowmark" },
            "2": { "name": "keyword.control.flowmark" }
          }
        },
        {
          "match": "(@)(for)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.keyword.flowmark" },
            "2": { "name": "keyword.control.flowmark" }
          }
        },
        {
          "match": "(@)(empty)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.keyword.flowmark" },
            "2": { "name": "keyword.control.flowmark" }
          }
        },
        {
          "match": "(@)(switch)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.keyword.flowmark" },
            "2": { "name": "keyword.control.flowmark" }
          }
        },
        {
          "match": "(@)(case)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.keyword.flowmark" },
            "2": { "name": "keyword.control.flowmark" }
          }
        },
        {
          "match": "(@)(default)\\b",
          "captures": {
            "1": { "name": "punctuation.definition.keyword.flowmark" },
            "2": { "name": "keyword.control.flowmark" }
          }
        }
      ]
    },
    "control-expression": {
      "name": "meta.control.expression.flowmark",
      "begin": "(?<=@(if|else if|for|switch|case)\\b)\\s*(\\()",
      "end": "\\)",
      "beginCaptures": {
        "2": { "name": "punctuation.section.parens.begin.flowmark" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.flowmark" }
      },
      "patterns": [
        { "include": "#nested-parens" },
        { "include": "#control-operator" },
        { "include": "source.js" }
      ]
    },
    "nested-parens": {
      "begin": "\\(",
      "end": "\\)",
      "beginCaptures": {
        "0": { "name": "punctuation.section.parens.begin.flowmark" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.flowmark" }
      },
      "patterns": [{ "include": "#nested-parens" }, { "include": "source.js" }]
    },
    "control-operator": {
      "match": "\\b(of|track)\\b",
      "name": "keyword.operator.word.flowmark"
    },
    "block": {
      "name": "meta.block.flowmark",
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.section.block.begin.flowmark" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.section.block.end.flowmark" }
      },
      "patterns": [{ "include": "$self" }]
    }
  }
}
