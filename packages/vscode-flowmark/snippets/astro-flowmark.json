{
  "Flowmark block": {
    "prefix": "flowmark",
    "body": [
      "<template flowmark={${1:context}} is:raw>",
      "  <main>",
      "    <h1>{{ context.${2:title} }}</h1>",
      "    $0",
      "  </main>",
      "</template>"
    ],
    "description": "Inline Flowmark block inside Astro"
  }
}
