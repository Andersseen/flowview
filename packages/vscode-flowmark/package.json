{
  "name": "vscode-flowmark",
  "displayName": "Flowmark Language Support",
  "description": "Syntax highlighting and snippets for Flowmark templates.",
  "version": "0.1.0",
  "private": true,
  "publisher": "andersseen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andersseen/flowmark.git",
    "directory": "packages/vscode-flowmark"
  },
  "scripts": {
    "dev": "code --new-window --extensionDevelopmentPath=\"$PWD\" ../../examples/astro-demo",
    "test": "node ./test/grammar.test.mjs",
    "package": "mkdir -p dist && vsce package --no-dependencies --out dist/flowmark-language-support.vsix",
    "package:pre-release": "mkdir -p dist && vsce package --no-dependencies --pre-release --out dist/flowmark-language-support.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.2",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "flowmark",
        "aliases": [
          "Flowmark",
          "flowmark"
        ],
        "extensions": [
          ".flow"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "flowmark",
        "scopeName": "source.flowmark",
        "path": "./syntaxes/flowmark.tmLanguage.json"
      },
      {
        "scopeName": "flowmark.astro.injection",
        "path": "./syntaxes/flowmark-astro-injection.tmLanguage.json",
        "injectTo": [
          "source.astro"
        ],
        "embeddedLanguages": {
          "meta.embedded.flowmark": "flowmark",
          "meta.interpolation.flowmark": "javascript",
          "meta.control.expression.flowmark": "javascript"
        }
      },
      {
        "scopeName": "flowmark.astro.raw.injection",
        "path": "./syntaxes/flowmark-astro-raw-injection.tmLanguage.json",
        "injectTo": [
          "source.astro"
        ]
      }
    ],
    "snippets": [
      {
        "language": "flowmark",
        "path": "./snippets/flowmark.json"
      },
      {
        "language": "astro",
        "path": "./snippets/astro-flowmark.json"
      }
    ]
  }
}
