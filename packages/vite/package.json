{
  "name": "@flowview/vite",
  "version": "0.1.0",
  "description": "Vite plugin for Flowmark templates.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/andersseen/flowmark.git",
    "directory": "packages/vite"
  },
  "bugs": {
    "url": "https://github.com/andersseen/flowmark/issues"
  },
  "homepage": "https://github.com/andersseen/flowmark/tree/main/packages/vite#readme",
  "keywords": [
    "flowmark",
    "template",
    "compiler",
    "vite",
    "plugin",
    "html"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./client.d.ts"
    }
  },
  "files": [
    "dist",
    "client.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@flowview/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0"
  }
}
