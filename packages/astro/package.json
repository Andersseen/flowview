{
  "name": "@flowview/astro",
  "version": "0.1.1",
  "description": "Astro integration for flowview templates.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/andersseen/flowview.git",
    "directory": "packages/astro"
  },
  "bugs": {
    "url": "https://github.com/andersseen/flowview/issues"
  },
  "homepage": "https://github.com/andersseen/flowview/tree/main/packages/astro#readme",
  "keywords": [
    "flowview",
    "astro",
    "template",
    "compiler",
    "integration"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/compiler": "^2.13.1",
    "@flowview/runtime": "workspace:^",
    "@flowview/vite": "workspace:^",
    "magic-string": "^0.30.21"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "astro": "^5.7.10",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "astro": "^5.0.0"
  }
}
