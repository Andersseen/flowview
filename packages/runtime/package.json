{
  "name": "@flowview/runtime",
  "version": "0.1.0",
  "description": "Tiny runtime for Flowmark-generated render functions.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/andersseen/flowmark.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/andersseen/flowmark/issues"
  },
  "homepage": "https://github.com/andersseen/flowmark/tree/main/packages/runtime#readme",
  "keywords": [
    "flowmark",
    "template",
    "compiler",
    "runtime",
    "html",
    "ssr"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
