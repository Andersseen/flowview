{
  "@if": {
    "prefix": "@if",
    "body": ["@if (${1:condition}) {", "  $0", "}"],
    "description": "flowview if block"
  },
  "@for": {
    "prefix": "@for",
    "body": [
      "@for (${1:item} of ${2:context.items}; track ${1:item}.${3:id}) {",
      "  $0",
      "} @empty {",
      "  ",
      "}"
    ],
    "description": "flowview for block with empty branch"
  },
  "@switch": {
    "prefix": "@switch",
    "body": [
      "@switch (${1:expression}) {",
      "  @case (${2:value}) {",
      "    $0",
      "  }",
      "  @default {",
      "    ",
      "  }",
      "}"
    ],
    "description": "flowview switch block"
  },
  "interpolation": {
    "prefix": "{{",
    "body": ["{{ ${1:context.value} }}"],
    "description": "flowview escaped interpolation"
  }
}
