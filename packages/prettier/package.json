{
  "name": "@flowview/prettier",
  "version": "0.1.1",
  "description": "Prettier plugin helpers for flowview templates in Astro files.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/andersseen/flowview.git",
    "directory": "packages/prettier"
  },
  "bugs": {
    "url": "https://github.com/andersseen/flowview/issues"
  },
  "homepage": "https://github.com/andersseen/flowview/tree/main/packages/prettier#readme",
  "keywords": [
    "flowview",
    "prettier",
    "astro",
    "template",
    "formatter"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "prettier-plugin-astro": "^0.14.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "prettier": "^3.5.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  }
}
